# GEMINI_API_KEY: Required for Gemini AI API calls.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# PORT: Server port (defaults to 3000)
PORT=3000

# NODE_ENV: Set to "production" for production builds
NODE_ENV=development

# GOOGLE_APPLICATION_CREDENTIALS: Path to Firebase service account key JSON
# Required for Firebase Admin SDK server-side auth verification.
# Download from: Firebase Console > Project Settings > Service Accounts > Generate New Private Key
GOOGLE_APPLICATION_CREDENTIALS="./service-account-key.json"

# --- Web3 / Blockchain ---
# Your MetaMask private key (export from MetaMask → Account Details → Export Private Key)
PRIVATE_KEY="your_metamask_private_key_here"

# Sepolia RPC URL
SEPOLIA_RPC_URL="https://rpc.sepolia.org"

# MonetroToken contract address (you get this after running: npm run deploy:sepolia in /blockchain)
MONETRO_TOKEN_ADDRESS="your_deployed_contract_address_here"
