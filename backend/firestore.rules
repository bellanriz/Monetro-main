rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }

    function getUserData(userId) {
      return get(/databases/$(database)/documents/users/$(userId)).data;
    }

    function isParentOf(kidId) {
      let kidData = getUserData(kidId);
      return isSignedIn() && kidData.parentId == request.auth.uid;
    }

    function isKidOf(parentId) {
      let myData = getUserData(request.auth.uid);
      return isSignedIn() && myData.parentId == parentId;
    }

    // Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Users collection
    match /users/{userId} {
      allow read: if isOwner(userId) || isParentOf(userId);
      allow create: if isSignedIn(); // Initially allow create for profile setup
      allow update: if isOwner(userId) || isParentOf(userId);
    }

    // Transactions collection
    match /transactions/{transactionId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId || 
        isParentOf(resource.data.userId)
      );
      allow create: if isSignedIn() && (
        request.auth.uid == request.resource.data.userId ||
        isParentOf(request.resource.data.userId)
      );
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        isParentOf(resource.data.userId)
      );
    }

    // Savings Goals
    match /savingsGoals/{goalId} {
      allow read: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        isParentOf(resource.data.userId)
      );
      allow create: if isSignedIn() && request.auth.uid == request.resource.data.userId;
      allow update: if isSignedIn() && (
        request.auth.uid == resource.data.userId ||
        isParentOf(resource.data.userId)
      );
      allow delete: if isSignedIn() && request.auth.uid == resource.data.userId;
    }
    
    // Invites
    match /invites/{inviteId} {
      allow read: if isSignedIn() && (
        request.auth.token.email == resource.data.parentEmail ||
        request.auth.token.email == resource.data.kidEmail
      );
      allow create: if isSignedIn();
      allow update: if isSignedIn();
    }
  }
}
